# Copy this file to `.secrets.env` (which is gitignored) and fill in the keys
# you have. Used only by the live provider tests in tests/test_providers.py.
# Tests for a provider are skipped automatically if its key is absent.
#
#   cp .secrets.env.example .secrets.env
#   # edit .secrets.env, then:
#   set -a; source .secrets.env; set +a
#   pytest tests/test_providers.py

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Alternatively, Google's SDK variable also works:
# GOOGLE_API_KEY=

# Ollama is local and needs no key — just run `ollama serve` and pull a model.
